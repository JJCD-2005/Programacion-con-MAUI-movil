<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CrudSqliteMAUI.MainPage">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20" RowSpacing="15">

        <Label Grid.Row="0" 
               Text="CRUD DE INVENTARIO (SQLite)" 
               FontSize="22" 
               FontAttributes="Bold" 
               HorizontalOptions="Center"
               TextColor="DarkSlateBlue"/>

        <VerticalStackLayout Grid.Row="1" Spacing="10">
            <Entry x:Name="nameEntry" Placeholder="Nombre del producto o repuesto"/>
            <Entry x:Name="quantityEntry" Placeholder="Cantidad disponible" Keyboard="Numeric"/>

            <Grid ColumnDefinitions="*,*">
                <Button x:Name="saveButton" 
                        Grid.Column="0"
                        Text="💾 Guardar" 
                        Clicked="OnSaveClicked" 
                        BackgroundColor="DarkGreen" 
                        TextColor="White" 
                        Margin="0,0,5,0"/>
                <Button x:Name="clearButton" 
                        Grid.Column="1"
                        Text="🧹 Limpiar" 
                        Clicked="OnClearClicked" 
                        BackgroundColor="DimGray" 
                        TextColor="White" 
                        Margin="5,0,0,0"/>
            </Grid>
        </VerticalStackLayout>

        <CollectionView x:Name="productsCollectionView" 
                        Grid.Row="2" 
                        SelectionMode="Single" 
                        SelectionChanged="OnSelectionChanged"
                        Margin="0,10,0,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold"/>
                            <Label Text="{Binding Quantity, StringFormat='Stock: {0} unidades'}" FontSize="14" TextColor="Gray"/>
                        </VerticalStackLayout>

                        <Button Grid.Column="1" 
                                Text="❌" 
                                Clicked="OnDeleteClicked" 
                                CommandParameter="{Binding .}" 
                                BackgroundColor="Transparent" 
                                TextColor="Red"
                                FontAttributes="Bold"
                                FontSize="18"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>