<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ListaTareasMAUI"
             x:Class="ListaTareasMAUI.MainPage"
             x:DataType="local:MainViewModel">

    <Grid RowDefinitions="Auto, Auto, *" Padding="20" RowSpacing="15">

        <Label Grid.Row="0" 
               Text="LISTA DE TAREAS" 
               FontSize="24" 
               FontAttributes="Bold" 
               HorizontalOptions="Center"/>

        <Grid Grid.Row="1" ColumnDefinitions="*, Auto" ColumnSpacing="10">
            <Entry Grid.Column="0" 
                   Text="{Binding NewTaskName}" 
                   Placeholder="¿Qué hay pa' hacer, perro?"/>
            <Button Grid.Column="1" 
                    Text="➕ Agregar" 
                    Command="{Binding AddTaskCommand}" 
                    BackgroundColor="Green" 
                    TextColor="White"/>
        </Grid>

        <CollectionView Grid.Row="2" ItemsSource="{Binding Tasks}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:TaskItem">
                    <Grid Padding="10" ColumnDefinitions="Auto, *, Auto">

                        <CheckBox x:Name="miCheckBox" 
                  IsChecked="{Binding IsCompleted, Mode=TwoWay}" 
                  VerticalOptions="Center"/>

                        <Label Grid.Column="1" 
               Text="{Binding Name}" 
               FontSize="16" 
               VerticalOptions="Center" 
               Margin="10,0">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" 
                             Binding="{Binding Source={x:Reference miCheckBox}, Path=IsChecked}" 
                             Value="True">
                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                    <Setter Property="TextColor" Value="Gray"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>

                        <Button Grid.Column="2" 
                Text="❌" 
                Command="{Binding Source={RelativeSource AncestorType={x:Type local:MainViewModel}}, Path=DeleteTaskCommand}" 
                CommandParameter="{Binding .}" 
                BackgroundColor="Transparent" 
                TextColor="Red"
                FontAttributes="Bold"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>